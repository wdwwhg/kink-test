---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
  robots?: string;
}

const {
  title,
  description,
  canonicalPath = "/",
  image = "/og-image.svg",
  jsonLd = [],
  bodyClass = "",
  robots = "index, follow, max-image-preview:large",
} = Astro.props;

const site = Astro.site ?? new URL("https://kinktest.xyz");
const canonical = new URL(canonicalPath, site).toString();
const imageUrl = new URL(image, site).toString();
const schemas = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#fffaf4" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {
      schemas.map((schema) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body class={bodyClass}>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-teal-800"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
