---
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--line)] bg-white">
  <div class="mx-auto grid max-w-6xl gap-6 px-4 py-10 text-sm text-[color:var(--muted)] sm:px-6 md:grid-cols-[1.2fr_0.8fr]">
    <div>
      <p class="font-bold text-[color:var(--ink)]">Kink Test</p>
      <p class="mt-2 max-w-2xl">
        An educational 18+ self-reflection tool for adults. It is not medical advice, therapy,
        diagnosis, or a substitute for explicit consent and safer-practice conversations.
      </p>
    </div>
    <div class="flex flex-wrap items-start gap-3 md:justify-end">
      <a class="font-semibold text-[color:var(--teal-dark)] hover:underline" href="/guides/consent-and-boundaries/">Consent</a>
      <a class="font-semibold text-[color:var(--teal-dark)] hover:underline" href="/guides/online-kink-test-privacy/">Privacy</a>
      <a class="font-semibold text-[color:var(--teal-dark)] hover:underline" href="/guides/aftercare-basics/">Aftercare</a>
    </div>
    <p class="md:col-span-2">© {year} kinktest.xyz. Answers stay in your browser.</p>
  </div>
</footer>
