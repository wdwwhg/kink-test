---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page Not Found | Kink Test";
const description =
  "This Kink Test page could not be found. Return to the private adult self-reflection quiz or browse consent-first guides.";
const canonicalPath = "/404.html";
const canonical = "https://kinktest.xyz/404.html";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    url: canonical,
    description,
    inLanguage: "en-US",
    isPartOf: {
      "@type": "WebSite",
      name: "Kink Test",
      url: "https://kinktest.xyz/",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Kink Test",
        item: "https://kinktest.xyz/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Page Not Found",
        item: canonical,
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  robots="noindex, nofollow"
>
  <SiteHeader />
  <main id="main" class="bg-[color:var(--paper)]">
    <section class="mx-auto max-w-4xl px-4 py-20 sm:px-6 sm:py-28" aria-labelledby="not-found-title">
      <p class="text-sm font-bold uppercase text-[color:var(--coral)]">404</p>
      <h1 id="not-found-title" class="mt-3 text-4xl font-black leading-tight text-[color:var(--ink)]">
        Page not found
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-[color:var(--muted)]">
        The page you requested does not exist. The private kink test and consent-first guides
        are still available from the main site.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/#test" class="rounded-md bg-[color:var(--teal)] px-5 py-3 text-sm font-bold text-white">
          Take the test
        </a>
        <a
          href="/guides/what-is-a-kink-test/"
          class="rounded-md border border-[color:var(--line)] bg-white px-5 py-3 text-sm font-bold text-[color:var(--teal-dark)]"
        >
          Read the guide
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
